{
  "rewrites": [
    { "source": "/api/members/:id", "destination": "/api/members/[id]" },
    { "source": "/api/events/:id", "destination": "/api/events/[id]" },
    { "source": "/api/blogs/:id", "destination": "/api/blogs/[id]" },
    { "source": "/api/notices/:id", "destination": "/api/notices/[id]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
