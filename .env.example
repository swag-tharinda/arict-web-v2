# Database
DATABASE_URL=postgres://user:password@hostname:5432/dbname

# API Authentication (Vercel Server)
ADMIN_SECRET=your_api_secret_key_here

# Client Login Gate (Browser)
VITE_ADMIN_PASSWORD=your_dashboard_password_here
VITE_ADMIN_SECRET=your_api_secret_key_here

